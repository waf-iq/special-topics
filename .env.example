# Copy to .env and fill in. Nothing here is required for D1 to run locally.

# Optional: override default arXiv API root
ARXIV_API_BASE=http://export.arxiv.org/api/query

# Optional: override default embedding model
EMBEDDING_MODEL=sentence-transformers/bge-small-en

# Optional: Optuna storage URL (default: in-memory). Use sqlite:///optuna_study.db to persist.
OPTUNA_STORAGE=

# Optional: limit number of PDFs ingested (useful for laptop testing)
INGEST_MAX_PDFS=50
